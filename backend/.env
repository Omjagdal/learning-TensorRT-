# ═══════════════════════════════════════════════════════════════════════════════
# Industrial Manual Chatbot — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Industrial Manual Chatbot"
APP_VERSION="2.0.0"
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/manuals

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RESULTS=5
RETRIEVAL_TOP_K=20
RERANKER_TOP_K=5

# ── Self-RAG Pipeline ────────────────────────────────────────────────────────
RELEVANCE_THRESHOLD=0.3
VALIDATION_ENABLED=true
MAX_RETRIES=1
CLASSIFY_ENABLED=true

# ── Qdrant Vector Database ───────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=industrial_manuals
QDRANT_USE_EMBEDDED=true
QDRANT_EMBEDDED_PATH=./data/qdrant_storage

# ── Embeddings (BGE-M3) ──────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# ── Reranker (BGE-Reranker-Large) ─────────────────────────────────────────────
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
RERANKER_ENABLED=true

# ── Hybrid Search ─────────────────────────────────────────────────────────────
HYBRID_SEARCH_ALPHA=0.6
BM25_ENABLED=true

# ── LLM (Qwen3 via Ollama) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
LLM_MAX_NEW_TOKENS=1024
LLM_TEMPERATURE=0.1

# ── LLM Fallback (HuggingFace Transformers) ──────────────────────────────────
LLM_FALLBACK_ENABLED=true
LLM_HF_MODEL_NAME=Qwen/Qwen3-8B

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
