{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ISRA Vision Chatbot",
  "version": "2.0.0",
  "identifier": "com.isravision.chatbot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ISRA Vision Chatbot",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "http://localhost:8765",
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {}
    },
    "resources": {
      "backend_server/": "resources/"
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://"
    }
  }
}
